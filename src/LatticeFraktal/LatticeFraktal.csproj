<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <!-- Laeuft damit auch auf einer .NET-10-Runtime, ohne dass die 9er-Runtime zwingend installiert sein muss -->
    <RollForward>Major</RollForward>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>lattice-fraktal</AssemblyName>
    <RootNamespace>LatticeFraktal</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <!-- PicoGK Geometrie-Kernel (bringt die nativen Windows-x64-Bibliotheken mit) -->
    <PackageReference Include="PicoGK" Version="2.0.0" />
  </ItemGroup>

</Project>
